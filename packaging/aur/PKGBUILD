pkgname=plasma6-applets-active-desktop-name
_pkgid=com.github.andresgarcia0313.activedesktopname
pkgver=1.2.1
pkgrel=1
pkgdesc="Plasma 6 widget that shows the name of the active virtual desktop"
arch=('any')
url="https://github.com/andresgarcia0313/plasma-active-desktop-name"
license=('GPL-3.0-only')
depends=('plasma-workspace')
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('553d6cf8ee3a807e3911a04d251a14437558d5e4c07e9485d4a8f99e223d95a3')

package() {
	cd "$srcdir/plasma-active-desktop-name-$pkgver"
	local _dest="$pkgdir/usr/share/plasma/plasmoids/$_pkgid"
	install -dm755 "$_dest"
	cp -a contents metadata.json "$_dest/"
}
